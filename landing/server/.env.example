# Обязательно: PostgreSQL с расширением PostGIS (см. docker-compose.yml в корне репозитория)
DATABASE_URL=postgresql://melody:melody@localhost:5432/melody

# Обязательно: секрет для JWT (минимум 16 символов), не публикуйте в git
JWT_SECRET=change-me-to-a-long-random-string

# SMTP для отправки формы обратной связи (например Gmail с паролем приложения)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
FEEDBACK_TO=your-email@gmail.com

# Опционально: чат GPT на бэкенде (без ключа чат отключён)
OPENAI_API_KEY=

# Опционально: порт API (по умолчанию 8787)
# PORT=8787

# Опционально: каталог загрузок mp3 (по умолчанию landing/server/uploads)
# UPLOADS_DIR=

# Опционально: origin для CORS (по умолчанию http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173
