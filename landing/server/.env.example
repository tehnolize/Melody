# База данных PostgreSQL
DATABASE_URL=postgresql://melody:melody@localhost:5432/melody

# JWT секрет (минимум 16 символов)
JWT_SECRET=change-me-to-a-long-random-string-32chars

# Порт сервера
PORT=8787

# CORS (адрес клиента)
CORS_ORIGIN=http://localhost:5173

# SMTP для формы обратной связи (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_gmail@gmail.com
FEEDBACK_TO=your_gmail@gmail.com

# OpenAI API для GPT чата (опционально)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
