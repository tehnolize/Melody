# SMTP для отправки формы обратной связи (например Gmail с паролем приложения)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
FEEDBACK_TO=your-email@gmail.com

# Опционально: чат GPT на бэкенде (без ключа чат отключён)
OPENAI_API_KEY=

# Опционально: порт API (по умолчанию 8787)
# PORT=8787

# Опционально: папка с музыкой для раздачи (по умолчанию относительный путь в коде)
# MUSIC_FOLDER=
